{
  "name": "brawltree-service",
  "private": true,
  "version": "1.0.0",
  "description": "Plant Brawl Tree",
  "scripts": {
    "build": "npm run build:frontend && npm run build:api",
    "build:api": "nest build",
    "build:frontend": "npm --prefix frontend run build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:test": "npm --prefix frontend run test",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "start:pm2": "pm2 start ./ecosystem.config.cjs --only bt-service",
    "start:pm2:prod": "pm2 start ./ecosystem.config.cjs --only bt-service",
    "start:pm2:backend": "pm2 start ./ecosystem.config.cjs --only bt-service-backend-dev",
    "start:pm2:frontend": "pm2 start ./ecosystem.config.cjs --only bt-service-frontend-dev",
    "start:pm2:both": "pm2 start ./ecosystem.config.cjs --only bt-service-backend-dev,bt-service-frontend-dev",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/typeorm": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cross-env": "^10.1.0",
    "http-proxy-middleware": "^3.0.5",
    "moment": "^2.30.1",
    "mysql2": "^3.22.0",
    "pm2": "^6.0.14",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laetipark/brawltree-backend.git"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "setupFiles": [
      "reflect-metadata"
    ],
    "moduleNameMapper": {
      "^~/common/(.*)$": "<rootDir>/common/$1",
      "^~/configs/(.*)$": "<rootDir>/configs/$1",
      "^~/database/(.*)$": "<rootDir>/database/$1",
      "^~/crew/(.*)$": "<rootDir>/features/crew/$1",
      "^~/brawlers/(.*)$": "<rootDir>/features/brawlers/$1",
      "^~/maps/(.*)$": "<rootDir>/features/maps/$1",
      "^~/seasons/(.*)$": "<rootDir>/features/seasons/$1",
      "^~/users/(.*)$": "<rootDir>/features/users/$1",
      "^~/utils/(.*)$": "<rootDir>/utils/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
