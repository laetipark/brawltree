# Vite 개발 서버 포트입니다.
VITE_PORT=

# 프런트엔드가 직접 호출할 API 기본 경로입니다. 비우면 /api를 사용합니다.
VITE_BASE_URL=

# 로컬 개발 중 /api 프록시가 바라볼 백엔드 주소입니다.
VITE_API_PROXY_TARGET=http://localhost:3000

# CDN 로케일 JSON을 원격에서 가져올지 여부입니다. true | false
VITE_CDN_REMOTE_LOCALES=

# 유튜브 뉴스/플레이리스트 조회에 사용하는 API 키입니다.
VITE_YOUTUBE_API_KEY=
