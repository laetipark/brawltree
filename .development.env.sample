# NestJS 서비스가 바인딩할 포트입니다.
HOST_PORT=

# crawler API 또는 내부 연동 서비스의 기본 URL입니다.
CRAWLER_HOST=

# MySQL 연결 정보입니다.
DATABASE_HOST=
DATABASE_PORT=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=

# DB 세션 타임존입니다. 비우면 코드 기본값(+09:00)을 사용합니다.
DATABASE_TIMEZONE=

# 사용자 배틀 조회 캐시 TTL(ms)입니다.
USER_BATTLES_QUERY_CACHE_TTL_MS=

# HTTP 로그 모드: off | error-slow | all
SERVICE_HTTP_LOG_MODE=error-slow
# 느린 HTTP 요청으로 간주할 기준(ms)입니다.
SERVICE_HTTP_SLOW_MS=3000

# SQL 로그 모드: off | error-slow | all
SERVICE_SQL_LOG_MODE=error-slow
# 느린 SQL 쿼리로 간주할 기준(ms)입니다.
SERVICE_SQL_SLOW_MS=3000

# SQL 바인딩 파라미터를 로그에 포함할지 여부입니다.
SERVICE_LOG_SQL_PARAMS=false
# 외부 HTTP 요청/응답 바디를 로그에 포함할지 여부입니다.
SERVICE_LOG_HTTP_BODY=false
